# Copy this file to .env on the private server.
# Keep the real CSV outside GitHub, or place it in ./data/ which is gitignored.
GRADE_CSV_PATH=./data/grades.csv
PORT=3000
# Set this when the backend is called from GitHub Pages.
GRADE_CORS_ORIGIN=https://719csy.github.io
# Google OAuth web client ID from Google Cloud Console.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# UCLA Google Workspace domains accepted by the backend.
GOOGLE_ALLOWED_DOMAINS=ucla.edu,g.ucla.edu
